# ============================================
# Konjyosom Tech Solutions - Environment Variables
# ============================================
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file or real credentials.

# MongoDB Atlas Connection
# Get your connection string from: https://www.mongodb.com/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-url.onrender.com

# Admin Default Credentials (seeded on first run)
# Change these after first deployment!
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

# ============================================
# RENDER DEPLOYMENT NOTES
# ============================================
# For Render.com deployment, use these settings:
#
# 1. Create Web Service (Node):
#    - Build Command: npm install
#    - Start Command: node server.js
#    - Environment: Node
#
# 2. Create Static Site (Frontend):
#    - Root Directory: ./frontend
#    - Build Command: echo "Ready" (no build needed)
#
# 3. Set Environment Variables in Render Dashboard:
#    - MONGODB_URI (your MongoDB Atlas URI)
#    - JWT_SECRET (generate a strong random string)
#
# 4. Update FRONTEND_URL to your static site URL after deployment
